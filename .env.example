# =========================
# Fixit env vars
# Copy to .env.local and fill in. Never commit .env.local.
# =========================

# OpenAI — vision + reasoning + (image gen via fal proxy, no direct key needed)
OPENAI_API_KEY=

# fal.ai — image gen (gpt-image-2/edit) + video gen (seedance-2.0/fast/i2v)
FAL_KEY=

# Tavily — /research with output_schema, /search + /extract as fallback
TAVILY_API_KEY=

# Gradium — TTS REST + STT WebSocket
GRADIUM_API_KEY=
# Default FR flagship voice; override per route if needed
GRADIUM_TTS_VOICE_ID=YTpq7expH9539ERJ
# Region: eu or us
GRADIUM_REGION=eu

# Vercel Blob — final video + intermediate assets
BLOB_READ_WRITE_TOKEN=

# Optional — only set if running with Redis-backed SSE channels
# (default boilerplate uses in-memory channels in lib/jobs.ts)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
